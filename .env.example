# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (format: ******HOST:PORT/DATABASE)
# Local Docker example:
DATABASE_URL="******localhost:5432/highsocietymn"

# ─── Authentication (Auth.js / NextAuth.js) ────────────────────────────────────
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ─── Cloudinary (optional — for image hosting) ────────────────────────────────
# Sign up at https://cloudinary.com/
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ─── Stripe (for payments) ────────────────────────────────────────────────────
# Get your keys at https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── Minnesota Tax Rate ────────────────────────────────────────────────────────
# Minnesota cannabis excise tax 10% + sales tax 6.875% = ~16.875%
MN_CANNABIS_TAX_RATE="0.1"
MN_SALES_TAX_RATE="0.06875"

# ─── Store Configuration ──────────────────────────────────────────────────────
STORE_NAME="High Society MN"
STORE_ADDRESS="Minneapolis, MN"
STORE_PHONE="+1 (612) 555-0100"
STORE_EMAIL="info@highsocietymn.com"

# ─── Scraper (optional) ────────────────────────────────────────────────────────
# Set to "false" to show the browser window during scraping
SCRAPER_HEADLESS="true"
